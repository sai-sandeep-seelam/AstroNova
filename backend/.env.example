
# N2YO API - Satellite Tracking
# Get your API key from: https://www.n2yo.com/api/
N2YO_API_KEY=your_n2yo_api_key_here

# NASA API - Space Data
# Get your API key from: https://api.nasa.gov/
NASA_API_KEY=your_nasa_api_key_here

# Astronomy API - Astronomy Data
# Get your credentials from: https://www.astronomyapi.com/
ASTRONOMY_APP_ID=your_astronomy_app_id_here
ASTRONOMY_APP_SECRET=your_astronomy_app_secret_here

# Google Gemini AI - AI Assistant
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional: Cache duration (in minutes)
CACHE_DURATION=5
